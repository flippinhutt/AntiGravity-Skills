{
  "name": "antigravity-skill-manager",
  "displayName": "Antigravity Skill Manager",
  "description": "Manage and build Antigravity skills directly in VSCode",
  "version": "1.0.0",
  "publisher": "ryanhutto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanhutto/antigravity-skill-manager"
  },
  "categories": ["Other"],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "antigravity",
          "title": "Antigravity",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "antigravity": [
        {
          "id": "antigravity.localSkills",
          "name": "Local Skills",
          "icon": "$(list-flat)"
        },
        {
          "id": "antigravity.remoteSkills",
          "name": "Remote Skills",
          "icon": "$(globe)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "antigravity.createSkill",
          "when": "view == antigravity.localSkills",
          "group": "navigation"
        },
        {
          "command": "antigravity.addRemoteRepo",
          "when": "view == antigravity.remoteSkills",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "antigravity.installSkill",
          "when": "view == antigravity.remoteSkills && viewItem == skill",
          "group": "inline"
        },
        {
          "command": "antigravity.removeRemoteRepo",
          "when": "view == antigravity.remoteSkills && viewItem == repo",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Antigravity Skill Manager",
      "properties": {
        "antigravity.skillRepositories": {
          "type": "array",
          "default": [
            "rominirani/antigravity-skills",
            "sickn33/antigravity-awesome-skills"
          ],
          "description": "List of GitHub repositories (format: owner/repo) to search for Antigravity skills.",
          "items": {
            "type": "string"
          }
        },
        "antigravity.customGlobalSkillsPath": {
          "type": "string",
          "default": "",
          "description": "Optional: Override the default global skills directory (~/.gemini/antigravity/skills). Use an absolute path or paths starting with '~'."
        },
        "antigravity.hideInvalidSkills": {
          "type": "boolean",
          "default": false,
          "description": "If true, hides any folders in your skills directories that do not contain a SKILL.md file."
        }
      }
    },
    "commands": [
      {
        "command": "antigravity.openSkillFile",
        "title": "Open Skill File"
      },
      {
        "command": "antigravity.githubLogin",
        "title": "Antigravity: Login to GitHub"
      },
      {
        "command": "antigravity.installSkill",
        "title": "Install Skill",
        "icon": "$(cloud-download)"
      },
      {
        "command": "antigravity.createSkill",
        "title": "Create New Skill",
        "icon": "$(add)"
      },
      {
        "command": "antigravity.showInvalidSkillError",
        "title": "Show Invalid Skill Error"
      },
      {
        "command": "antigravity.addRemoteRepo",
        "title": "Add Remote Repository",
        "icon": "$(add)"
      },
      {
        "command": "antigravity.removeRemoteRepo",
        "title": "Remove Repository",
        "icon": "$(trash)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node ./esbuild.js --production",
    "watch": "node ./esbuild.js --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}

{
  "name": "antigravity-skill-manager",
  "displayName": "Antigravity Skill Manager",
  "description": "Manage and build Antigravity skills directly in VSCode",
  "version": "1.0.0",
  "publisher": "ryanhutto",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "antigravity",
          "title": "Antigravity",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "antigravity": [
        {
          "id": "antigravity.localSkills",
          "name": "Local Skills",
          "icon": "$(list-flat)"
        },
        {
          "id": "antigravity.remoteSkills",
          "name": "Remote Skills",
          "icon": "$(globe)"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "antigravity.installSkill",
          "when": "view == antigravity.remoteSkills && viewItem == skill",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Antigravity Skill Manager",
      "properties": {
        "antigravity.skillRepositories": {
          "type": "array",
          "default": [
            "rominirani/antigravity-skills",
            "sickn33/antigravity-awesome-skills"
          ],
          "description": "List of GitHub repositories (format: owner/repo) to search for Antigravity skills.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "commands": [
      {
        "command": "antigravity.openSkillFile",
        "title": "Open Skill File"
      },
      {
        "command": "antigravity.githubLogin",
        "title": "Antigravity: Login to GitHub"
      },
      {
        "command": "antigravity.installSkill",
        "title": "Install Skill",
        "icon": "$(cloud-download)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node ./esbuild.js --production",
    "watch": "node ./esbuild.js --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}
